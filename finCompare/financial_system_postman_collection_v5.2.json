  "item": [
    {
      "name": "1. Product Intelligence Layer (PIL)",
      "item": [
        {
          "name": "Query Products",
          "request": {
            "method": "GET",
            "url": "http://163.245.222.160/products?product_type=savings_account&jurisdiction=PK"
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "http://163.245.222.160/products/PK_HBL_SAVINGS_001_v3"
          }
        },
        {
          "name": "Ingest Product Feed",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_id\": \"TEST_BANK\",\n  \"schema_hash\": \"sha256:abc1234567890abcdef\",\n  \"products\": [\n    {\n      \"product_type\": \"savings_account\",\n      \"jurisdiction\": [\"PK\"],\n      \"status\": \"active\",\n      \"version\": \"1\",\n      \"last_updated\": \"2026-05-05T00:00:00Z\",\n      \"pricing\": {\"base_rate_percent\": 10, \"currency\": \"PKR\", \"fees\": {}, \"frequency\": \"monthly\"},\n      \"eligibility_rules\": {\"rules\": []},\n      \"features\": [],\n      \"compliance\": {\"sharia_certified\": false}\n    }\n  ]\n}"
            },
            "url": "http://163.245.222.160/provider/ingest"
          }
        },
        {
          "name": "Validate Product",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_id\": \"TEST_BANK\",\n  \"product_type\": \"savings_account\",\n  \"jurisdiction\": [\"PK\"],\n  \"status\": \"active\",\n  \"version\": \"1\",\n  \"last_updated\": \"2026-05-05T00:00:00Z\",\n  \"pricing\": {},\n  \"eligibility_rules\": {},\n  \"features\": [],\n  \"compliance\": {}\n}"
            },
            "url": "http://163.245.222.160/validate/product"
          }
        }
      ]
    },
