{
  "spec": {
    "template": {
      "spec": {
        "containers": [
          {
            "name": "nginx",
            "volumeMounts": [
              {
                "name": "html-volume",
                "mountPath": "/usr/share/nginx/html"
              },
              {
                "name": "nginx-config",
                "mountPath": "/etc/nginx/conf.d"
              }
            ]
          }
        ],
        "volumes": [
          {
            "name": "html-volume",
            "configMap": {
              "name": "frontend-html",
              "defaultMode": 420
            }
          },
          {
            "name": "nginx-config",
            "configMap": {
              "name": "frontend-nginx-config",
              "defaultMode": 420
            }
          }
        ]
      }
    }
  }
}
